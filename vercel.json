{
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "opentune-canvas.vercel.app"
        }
      ],
      "destination": "https://wormhole-canvas.vercel.app/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api",
      "has": [
        {
          "type": "query",
          "key": "action",
          "value": "list"
        }
      ],
      "destination": "/api/list"
    },
    {
      "source": "/api",
      "has": [
        {
          "type": "query",
          "key": "action",
          "value": "upload"
        }
      ],
      "destination": "/api/upload"
    },
    {
      "source": "/api",
      "has": [
        {
          "type": "query",
          "key": "action",
          "value": "delete"
        }
      ],
      "destination": "/api/delete"
    },
    {
      "source": "/api",
      "has": [
        {
          "type": "query",
          "key": "action",
          "value": "search"
        }
      ],
      "destination": "/api/search"
    },
    {
      "source": "/api/blob/:path*",
      "destination": "/api/blob?path=:path*"
    }
  ]
}
